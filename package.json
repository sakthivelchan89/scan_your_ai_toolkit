{
  "name": "@maiife/toolkit",
  "version": "0.2.2",
  "private": true,
  "description": "Open-source AI governance toolkit — MCP servers + CLI tools",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:conformance": "turbo test:conformance",
    "lint": "turbo lint",
    "security": "pnpm audit --audit-level=high && npx eslint \"packages/*/src/**/*.ts\" --max-warnings 0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "turbo": "^2.9.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "Apache-2.0",
  "pnpm": {
    "overrides": {
      "vite": ">=7.3.2",
      "hono": ">=4.12.12",
      "@hono/node-server": ">=1.19.13"
    }
  }
}
