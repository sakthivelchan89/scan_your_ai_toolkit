{
  "name": "@maiife-ai-pub/prompt-craft",
  "version": "0.2.2",
  "description": "Gamified Personal Prompt Coach — Duolingo for AI prompting with levels, streaks, and badges",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "maiife-prompt-craft": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:conformance": "vitest run --config vitest.conformance.config.ts"
  },
  "dependencies": {
    "@maiife-ai-pub/prompt-score": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.1.0",
    "@maiife-ai-pub/shared": "workspace:*"
  },
  "license": "Apache-2.0",
  "author": "Maiife <contact@maiife.ai> (https://maiife.ai)",
  "keywords": [
    "maiife",
    "prompt-engineering",
    "coaching",
    "gamification",
    "ai-productivity",
    "prompting",
    "ai-governance"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sakthivelchan89/scan_your_ai_toolkit",
    "directory": "packages/prompt-craft"
  },
  "homepage": "https://github.com/sakthivelchan89/scan_your_ai_toolkit/tree/main/packages/prompt-craft"
}
