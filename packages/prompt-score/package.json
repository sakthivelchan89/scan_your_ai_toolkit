{
  "name": "@maiife-ai-pub/prompt-score",
  "version": "0.1.3",
  "description": "Prompt quality analyzer — score, improve, and lint your AI prompts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "maiife-prompt-score": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:conformance": "vitest run --config vitest.conformance.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.1.0",
    "@maiife-ai-pub/shared": "workspace:*"
  },
  "license": "Apache-2.0",
  "author": "Maiife <contact@maiife.ai> (https://maiife.ai)",
  "keywords": [
    "maiife",
    "ai-governance",
    "prompt",
    "prompt-quality",
    "prompt-engineering",
    "llm",
    "mcp"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sakthivelchan89/scan_your_ai_toolkit",
    "directory": "packages/prompt-score"
  },
  "homepage": "https://github.com/sakthivelchan89/scan_your_ai_toolkit/tree/main/packages/prompt-score"
}
