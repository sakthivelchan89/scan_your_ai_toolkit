{
  "name": "@maiife-ai-pub/probe",
  "version": "0.1.3",
  "description": "AI environment scanner — discover IDE extensions, MCP servers, agent frameworks, API keys, local models",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "maiife-probe": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:conformance": "vitest run --config vitest.conformance.config.ts"
  },
  "dependencies": {
    "@maiife-ai-pub/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.1.0"
  },
  "license": "Apache-2.0",
  "keywords": [
    "maiife",
    "ai-governance",
    "mcp",
    "ai-environment",
    "scanner",
    "ide-extensions",
    "api-keys"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sakthivelchan89/scan_your_ai_toolkit",
    "directory": "packages/probe"
  },
  "homepage": "https://github.com/sakthivelchan89/scan_your_ai_toolkit/tree/main/packages/probe",
  "author": "Maiife <contact@maiife.ai> (https://maiife.ai)"
}
