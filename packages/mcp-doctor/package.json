{
  "name": "@maiife-ai-pub/mcp-doctor",
  "version": "0.2.2",
  "description": "MCP Server Health Check & Auto-Fixer — brew doctor for your MCP setup",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "maiife-mcp-doctor": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:conformance": "vitest run --config vitest.conformance.config.ts"
  },
  "dependencies": {
    "@maiife-ai-pub/mcp-audit": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.1.0",
    "@maiife-ai-pub/shared": "workspace:*"
  },
  "license": "Apache-2.0",
  "author": "Maiife <contact@maiife.ai> (https://maiife.ai)",
  "keywords": [
    "maiife",
    "mcp",
    "health-check",
    "doctor",
    "model-context-protocol",
    "ai-governance",
    "devtools"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sakthivelchan89/scan_your_ai_toolkit",
    "directory": "packages/mcp-doctor"
  },
  "homepage": "https://github.com/sakthivelchan89/scan_your_ai_toolkit/tree/main/packages/mcp-doctor"
}
