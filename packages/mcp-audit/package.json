{
  "name": "@maiife-ai-pub/mcp-audit",
  "version": "0.1.3",
  "description": "MCP server security scanner — score configurations on permissions, data sensitivity, blast radius",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "maiife-mcp-audit": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:conformance": "vitest run --config vitest.conformance.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.1.0",
    "@maiife-ai-pub/shared": "workspace:*"
  },
  "license": "Apache-2.0",
  "keywords": [
    "maiife",
    "mcp",
    "security",
    "audit",
    "scanner",
    "model-context-protocol",
    "ai-governance"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Maiife <contact@maiife.ai> (https://maiife.ai)",
  "repository": {
    "type": "git",
    "url": "https://github.com/sakthivelchan89/scan_your_ai_toolkit",
    "directory": "packages/mcp-audit"
  },
  "homepage": "https://github.com/sakthivelchan89/scan_your_ai_toolkit/tree/main/packages/mcp-audit"
}
