{
  "name": "@maiife-ai-pub/trace",
  "version": "0.1.4",
  "description": "Agent workflow tracer — trace, view, and analyze agent execution spans",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "maiife-trace": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:conformance": "vitest run --config vitest.conformance.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.1.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.1.0",
    "@maiife-ai-pub/shared": "workspace:*"
  },
  "license": "Apache-2.0",
  "author": "Maiife <contact@maiife.ai> (https://maiife.ai)",
  "keywords": [
    "maiife",
    "ai-governance",
    "tracing",
    "agent",
    "observability",
    "spans",
    "workflow",
    "mcp"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sakthivelchan89/scan_your_ai_toolkit",
    "directory": "packages/trace"
  },
  "homepage": "https://github.com/sakthivelchan89/scan_your_ai_toolkit/tree/main/packages/trace"
}
